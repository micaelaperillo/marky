{
	"dependencies": {
		"@aws-sdk/client-dynamodb": "^3.0.0",
		"cookie-parser": "^1.4.6",
		"dayjs": "^1.11.0",
		"express": "^4.18.0",
		"pino": "^10.3.1",
		"serverless-http": "^3.2.0",
		"zod": "^4.4.2"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.14",
		"@types/cookie-parser": "^1.4.0",
		"@types/express": "^4.17.0",
		"esbuild": "^0.21.0",
		"tsconfig-paths": "^4.2.0",
		"tsx": "^4.0.0",
		"typescript": "^5.5.0"
	},
	"name": "marky-api",
	"scripts": {
		"build": "esbuild src/index.ts --bundle --minify --platform=node --target=node20 --outfile=dist/index.js --format=cjs --external:@aws-sdk/client-dynamodb --alias:@shared=./src/shared --alias:@domains=./src/domains",
		"dev": "tsx watch --require tsconfig-paths/register src/app.ts",
		"lint": "biome check src --fix",
		"start": "node dist/index.js"
	}
}
