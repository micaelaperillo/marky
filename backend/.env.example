# AWS
AWS_REGION=us-east-1

# S3
MARKY_POLYMARKET_RAW_DATA_S3_BUCKET=marky-polymarket-raw-data-10

# DynamoDB (single-table design — partition key prefixes namespace entities)
MARKY_DYNAMO_DATA_TABLE=marky-data

# Polymarket Gamma API
MARKY_GAMMA_BASE_URL=https://gamma-api.polymarket.com
MARKY_GAMMA_TIMEOUT_SECONDS=20
MARKY_GAMMA_MAX_RETRIES=5

# Logging
MARKY_LOG_LEVEL=INFO
